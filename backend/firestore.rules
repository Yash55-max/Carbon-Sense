rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isValidState() {
      let data = request.resource.data;
      return data.monthlyFootprint is number
          && data.monthlyFootprint >= 0
          && data.monthlyFootprint <= 10000
          && data.streakDays is number
          && data.streakDays >= 0;
    }

    // ── User documents: strict per-user isolation ──────────────────────────────

    match /users/{uid}/{document=**} {
      // Only the authenticated owner can read/write their own data
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    // ── Leaderboard: any authenticated user can read; only owner can write ────

    match /leaderboard/{uid} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(uid);
    }

    // ── Default: deny all ─────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
